# Filename: {{ output_path }}
# Borgmatic configuration for backing up {{ backup_name }}
# Generated by Scaffoldr on {{ generation_timestamp }}
# Compatible with borgmatic 1.8+

source_directories:
    - {{ source_directory }}
{%- if db_type and db_type != 'none' %}
    - {{ dump_path }}
{%- endif %}

repositories:
    - path: {{ repository_path }}
      label: {{ repository_label if repository_label else backup_name }}
{%- if remote_path and remote_path != 'borg' %}
      remote_path: {{ remote_path }}
{%- endif %}

{%- if exclude_patterns %}
exclude_patterns:
{%- for pattern in exclude_patterns %}
    - '{{ pattern }}'
{%- endfor %}

{%- endif %}
{%- if encryption_passphrase %}
encryption_passphrase: '{{ encryption_passphrase }}'

{%- endif %}
{%- set archive_prefix = archive_name_format if archive_name_format else backup_name %}
archive_name_format: '{{ archive_prefix }}-{now:%Y-%m-%dT%H:%M:%S}'

keep_daily: {{ retention_daily }}
keep_weekly: {{ retention_weekly }}
keep_monthly: {{ retention_monthly }}
keep_yearly: {{ retention_yearly }}
{%- if retention_hourly and retention_hourly|int > 0 %}
keep_hourly: {{ retention_hourly }}
{%- endif %}

checks:
{%- if consistency_checks and 'none' not in consistency_checks %}
{%- for check in consistency_checks %}
    - name: {{ check }}
{%- endfor %}
{%- else %}
    []
{%- endif %}

hooks:
    before_backup:
        - echo "Starting backup for '{{ backup_name }}'..."
{%- if db_type and db_type != 'none' %}
        - mkdir -p {{ dump_path }}
{%- if db_type == 'mysql' %}
        - mysqldump -h {{ db_host }} -P {{ db_port if db_port else '3306' }} -u {{ db_user }} -p'{{ db_password }}' {{ db_name }} | gzip > {{ dump_path }}/{{ db_name }}-$(date +%F).sql.gz
{%- elif db_type == 'postgres' %}
        - PGPASSWORD='{{ db_password }}' pg_dump -h {{ db_host }} -p {{ db_port if db_port else '5432' }} -U {{ db_user }} {{ db_name }} | gzip > {{ dump_path }}/{{ db_name }}-$(date +%F).sql.gz
{%- elif db_type == 'wordpress' %}
        - wp db export {{ dump_path }}/{{ db_name }}-$(date +%F).sql --allow-root --path=/var/www/html && gzip -f {{ dump_path }}/{{ db_name }}-$(date +%F).sql
{%- elif db_type == 'docker-mysql' %}
        - docker exec {{ docker_container_name }} mysqldump -u {{ db_user }} -p'{{ db_password }}' {{ db_name }} | gzip > {{ dump_path }}/{{ db_name }}-$(date +%F).sql.gz
{%- elif db_type == 'docker-postgres' %}
        - docker exec {{ docker_container_name }} pg_dump -U {{ db_user }} {{ db_name }} | gzip > {{ dump_path }}/{{ db_name }}-$(date +%F).sql.gz
{%- endif %}
{%- endif %}
{%- if healthcheck_url %}
        - curl -fsS -m 10 --retry 5 -o /dev/null "{{ healthcheck_url }}/start"
{%- endif %}

    after_backup:
        - echo "Backup for '{{ backup_name }}' complete."
{%- if healthcheck_url %}
        - curl -fsS -m 10 --retry 5 -o /dev/null "{{ healthcheck_url }}"
{%- endif %}

    on_error:
        - echo "An error occurred during the '{{ backup_name }}' backup."
{%- if healthcheck_url %}
        - curl -fsS -m 10 --retry 5 -o /dev/null "{{ healthcheck_url }}/fail"
{%- endif %}
